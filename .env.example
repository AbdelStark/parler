# parler local environment
#
# Copy to `.env`, then fill in the real key value.
# The CLI/TUI/E2E helper read `MISTRAL_API_KEY` directly.

MISTRAL_API_KEY=

# Optional compatibility alias. Leave unset unless you have tooling that already
# exports `PARLER_API_KEY`; parler will map it to `MISTRAL_API_KEY`.
# PARLER_API_KEY=

# Optional live-E2E defaults. The bundled `parler-e2e` wrapper uses a
# key-compatible extraction model unless you override it here.
# PARLER_E2E_EXTRACTION_MODEL=mistral-medium-latest
# PARLER_E2E_TRANSCRIPTION_MODEL=voxtral-mini-latest

# Optional local cache override.
# PARLER_CACHE_DIRECTORY=.parler-cache
